MONGO_URI=mongodb://localhost:27017/healthcare-ui
JWT_SECRET=change_this_to_a_long_random_string
PORT=5000

# Gmail Configuration for Contact Form Emails
GMAIL_USER=your_email@gmail.com
# IMPORTANT: Use App Password, not your regular Gmail password
# Steps to create App Password:
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer"
# 4. Google will generate a 16-character app password
# 5. Use that password below (without spaces)
GMAIL_PASSWORD=your_app_password_here

# Contact email (where form submissions are sent)
CONTACT_EMAIL=your_email@gmail.com

# Razorpay Payment Gateway
# Sign up at https://dashboard.razorpay.com
# Get your keys from Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Optional settings
# REQUIRED in production: comma-separated list of allowed frontend origins
# e.g. FRONTEND_ORIGIN=https://yourapp.com,https://www.yourapp.com
FRONTEND_ORIGIN=http://localhost:5173

# OpenAI API key (for AI health chatbot)
# OPENAI_API_KEY=sk-...

# Reminder channels
ENABLE_SMS_REMINDERS=false
ENABLE_EMAIL_REMINDERS=false
DEFAULT_COUNTRY_CODE=+91
EMAIL_FROM=notifications@healthpro.local

# Optional SMTP (preferred over Gmail if provided)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password

# Twilio SMS (required when ENABLE_SMS_REMINDERS=true)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+12345678900